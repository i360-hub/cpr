---
// Blog index (hub) — /blog. Lists all posts newest-first from blogPosts.ts.
import ResponsivePicture from "@components/ui/ResponsivePicture.astro";
import type { ImageMetadata } from "astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHeader from "@components/layout/PageHeader.astro";
import FinalCta from "@components/widgets/FinalCta.astro";
import ContactForm from "@components/widgets/ContactForm.astro";
import Icon from "@components/ui/Icon.astro";
import { blogPosts } from "@data/blogPosts";

const images = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/images/blog/*.{jpg,jpeg,png,webp}",
  { eager: true }
);
const imgFor = (slug: string) => {
  const key = Object.keys(images).find((k) => k.includes(`/blog/${slug}.`));
  return key ? images[key].default : undefined;
};

const [featured, ...rest] = blogPosts;
const featImg = imgFor(featured.slug);

// The featured image is this page's LCP element. Shared by the head preload and
// the <ResponsivePicture> below — keep them pointing at the same object.
const FEAT_WIDTHS = [480, 768, 1024];
const FEAT_SIZES = "(max-width: 900px) 100vw, 55vw";
---

<BaseLayout
  title="Water Damage & Mold Remediation Blog | Carolina Pro Restoration | Fort Mill SC"
  description="Get expert water damage & mold remediation guides. Ensure your home is safe & dry. Tips from the Carolina Pro Restoration team in Fort Mill, SC."
  path="/blog"
  preloadImage={featImg && { src: featImg, widths: FEAT_WIDTHS, sizes: FEAT_SIZES }}
>
  <PageHeader
    eyebrow="From the CPR Team"
    title="Water Damage &amp; Restoration Guides"
    subtitle="Practical, local advice on water damage, mold, crawl spaces, and insurance — written by the Fort Mill crew who handles these jobs every day."
  />

  <section class="cpr-section">
    <div class="cpr-section-inner">
      <!-- Featured -->
      <a href={`/${featured.slug}`} class="blog-feat">
        {featImg && (
          <div class="blog-feat__media">
            <ResponsivePicture src={featImg} alt={featured.title} widths={FEAT_WIDTHS} sizes={FEAT_SIZES} priority={true} />
          </div>
        )}
        <div class="blog-feat__body">
          <p class="blog-meta">
            <span class="blog-tag">Latest</span>
            <span>{featured.dateLabel}</span>
            <span>· {featured.readMinutes} min read</span>
          </p>
          <h2 class="blog-feat__title">{featured.title}</h2>
          <p class="blog-feat__desc">{featured.description}</p>
          <span class="blog-more">Read the guide <Icon name="arrow" /></span>
        </div>
      </a>

      <!-- Grid -->
      <ul class="blog-grid" role="list">
        {
          rest.map((p) => {
            const img = imgFor(p.slug);
            return (
              <li class="blog-card">
                <a href={`/${p.slug}`}>
                  {img && (
                    <div class="blog-card__media">
                      <ResponsivePicture src={img} alt={p.title} widths={[400, 640]} sizes="(max-width: 700px) 100vw, 360px" />
                    </div>
                  )}
                  <div class="blog-card__body">
                    <p class="blog-meta">
                      <span>{p.dateLabel}</span>
                      <span>· {p.readMinutes} min</span>
                    </p>
                    <h3 class="blog-card__title">{p.title}</h3>
                    <p class="blog-card__desc">{p.description}</p>
                    <span class="blog-more">Read more <Icon name="arrow" /></span>
                  </div>
                </a>
              </li>
            );
          })
        }
      </ul>
    </div>
  </section>

  <FinalCta heading="Have a Water Damage Emergency? Don't Wait — Call Us." />

  <ContactForm heading="Get Fast, Local Help" formName="Blog Index Contact" />
</BaseLayout>

<style>
  .blog-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    font-size: 0.85rem;
    color: var(--cpr-slate-muted);
    margin-bottom: 0.6rem;
  }
  .blog-tag {
    background: rgba(211, 47, 47, 0.1);
    color: var(--cpr-red);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 0.72rem;
    padding: 0.2rem 0.6rem;
    border-radius: var(--cpr-radius-pill);
  }
  .blog-more {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-weight: 700;
    color: var(--cpr-red);
    margin-top: auto;
  }
  .blog-more :global(svg) {
    width: 1em;
    height: 1em;
    transition: transform 0.15s ease;
  }

  /* Featured */
  .blog-feat {
    display: grid;
    grid-template-columns: 55% 1fr;
    gap: var(--cpr-space-xl);
    align-items: center;
    background: var(--cpr-white);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: var(--cpr-radius-lg);
    overflow: hidden;
    box-shadow: var(--cpr-shadow-sm);
    margin-bottom: var(--cpr-space-2xl);
    transition: box-shadow 0.15s ease, transform 0.15s ease;
  }
  .blog-feat:hover {
    box-shadow: var(--cpr-shadow-md);
    transform: translateY(-2px);
  }
  .blog-feat:hover .blog-more :global(svg) {
    transform: translateX(3px);
  }
  .blog-feat__media {
    aspect-ratio: 16 / 11;
    overflow: hidden;
  }
  .blog-feat__media :global(picture) {
    display: block;
    width: 100%;
    height: 100%;
  }
  .blog-feat__media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .blog-feat__body {
    display: flex;
    flex-direction: column;
    padding: var(--cpr-space-xl) var(--cpr-space-xl) var(--cpr-space-xl) 0;
  }
  .blog-feat__title {
    font-size: clamp(1.4rem, 2.6vw, 1.9rem);
    margin-bottom: 0.6rem;
  }
  .blog-feat__desc {
    color: var(--cpr-slate);
    line-height: 1.6;
    margin-bottom: var(--cpr-space-md);
  }

  /* Grid */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--cpr-space-xl);
  }
  .blog-card {
    background: var(--cpr-white);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: var(--cpr-radius-lg);
    overflow: hidden;
    box-shadow: var(--cpr-shadow-sm);
    transition: box-shadow 0.15s ease, transform 0.15s ease, border-color 0.15s ease;
  }
  .blog-card:hover {
    box-shadow: var(--cpr-shadow-md);
    transform: translateY(-3px);
    border-color: var(--cpr-red);
  }
  .blog-card a {
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  .blog-card__media {
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }
  .blog-card__media :global(picture) {
    display: block;
    width: 100%;
    height: 100%;
  }
  .blog-card__media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .blog-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: var(--cpr-space-lg);
    flex: 1;
  }
  .blog-card__title {
    font-size: 1.12rem;
    line-height: 1.3;
  }
  .blog-card__desc {
    color: var(--cpr-slate);
    font-size: 0.92rem;
    line-height: 1.55;
    margin-bottom: var(--cpr-space-sm);
  }
  .blog-card:hover .blog-more :global(svg) {
    transform: translateX(3px);
  }

  @media (max-width: 900px) {
    .blog-feat {
      grid-template-columns: 1fr;
    }
    .blog-feat__body {
      padding: 0 var(--cpr-space-xl) var(--cpr-space-xl);
    }
    .blog-feat__media :global(img) {
      max-height: 260px;
    }
    .blog-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 560px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
