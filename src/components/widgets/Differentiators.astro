---
// Differentiator section (cpr-diff) + the Others-vs-CPR comparison table (cpr-compare).
// These are one visual unit on the live site, so they live in one component.
import SectionHeader from "@components/ui/SectionHeader.astro";
import Icon from "@components/ui/Icon.astro";

type Cell = "yes" | "no" | "sometimes";
interface Row {
  feature: string;
  others: Cell;
  cpr: Cell;
}
interface Props {
  title?: string;
  sub?: string;
  othersLabel?: string;
  cprLabel?: string;
  rows?: Row[];
}
const {
  title = "What Sets a Full-Service Restoration Company Apart",
  sub = "Most companies only do the emergency part — they rip out the wet materials and leave. Then you hire a second contractor for drywall, a third for paint, a fourth for flooring. Carolina Pro Restoration does the whole job with one crew and one project manager.",
  othersLabel = "Others",
  cprLabel = "CPR",
  rows = [
    { feature: "Emergency water extraction", others: "yes", cpr: "yes" },
    { feature: "Structural drying with daily monitoring", others: "sometimes", cpr: "yes" },
    { feature: "Drywall, paint, trim & flooring rebuild", others: "no", cpr: "yes" },
    { feature: "IICRC certified technicians", others: "sometimes", cpr: "yes" },
    { feature: "Thermal imaging on every job", others: "no", cpr: "yes" },
    { feature: "Direct insurance billing (Xactimate)", others: "sometimes", cpr: "yes" },
    { feature: "One dedicated project manager", others: "no", cpr: "yes" },
    { feature: "Licensed in SC and NC", others: "sometimes", cpr: "yes" },
    { feature: "Locally owned & operated", others: "sometimes", cpr: "yes" },
  ],
} = Astro.props;

// "yes"/"no" render as icons (unambiguous); "sometimes" renders as the word
// "Varies" — a bare dash forces the reader to guess what it means.
const cell = (v: Cell) =>
  v === "yes"
    ? { icon: "check", cls: "is-yes", label: "Included" }
    : v === "no"
      ? { icon: "x", cls: "is-no", label: "Typically not offered" }
      : { icon: null, cls: "is-maybe", label: "Varies by company" };
---

<section class="cpr-section diff">
  <div class="cpr-section-inner">
    <SectionHeader title={title} sub={sub} />

    <div class="diff__tablewrap">
      <table class="diff__table">
        <thead>
          <tr>
            <th scope="col" class="diff__feat">What you get</th>
            <th scope="col">{othersLabel}</th>
            <th scope="col" class="diff__cpr">{cprLabel}</th>
          </tr>
        </thead>
        <tbody>
          {
            rows.map((r) => {
              const o = cell(r.others);
              const c = cell(r.cpr);
              return (
                <tr>
                  <th scope="row" class="diff__feat" set:html={r.feature} />
                  <td>
                    {o.icon ? (
                      <span class:list={["diff__mark", o.cls]} role="img" aria-label={o.label} title={o.label}><Icon name={o.icon} /></span>
                    ) : (
                      <span class:list={["diff__pill", o.cls]} title={o.label}>Varies</span>
                    )}
                  </td>
                  <td class="diff__cpr">
                    {c.icon ? (
                      <span class:list={["diff__mark", c.cls]} role="img" aria-label={c.label} title={c.label}><Icon name={c.icon} /></span>
                    ) : (
                      <span class:list={["diff__pill", c.cls]} title={c.label}>Varies</span>
                    )}
                  </td>
                </tr>
              );
            })
          }
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .diff__tablewrap {
    max-width: 820px;
    margin-inline: auto;
    overflow-x: auto;
    border-radius: var(--cpr-radius-lg);
    box-shadow: var(--cpr-shadow-md);
  }
  .diff__table {
    width: 100%;
    border-collapse: collapse;
    background: var(--cpr-white);
    min-width: 480px;
  }
  .diff__table th,
  .diff__table td {
    padding: 1rem 1.25rem;
    text-align: center;
    border-bottom: 1px solid rgba(0, 0, 0, 0.07);
  }
  .diff__table thead th {
    background: var(--cpr-navy);
    color: var(--cpr-white);
    font-size: 0.95rem;
  }
  /* Scoped under .diff__table so this wins over the `.diff__table th` centering
     rule above (higher specificity) — feature labels must be left-aligned. */
  .diff__table .diff__feat {
    text-align: left;
    font-weight: 600;
    color: var(--cpr-navy);
  }
  thead .diff__feat {
    color: var(--cpr-white);
  }
  .diff__cpr {
    background: rgba(211, 47, 47, 0.06);
  }
  thead .diff__cpr {
    background: var(--cpr-red);
  }
  .diff__mark {
    display: inline-grid;
    place-items: center;
    width: 1.9rem;
    height: 1.9rem;
    border-radius: 50%;
    font-size: 0.9rem;
  }
  .diff__mark.is-yes {
    background: rgba(22, 163, 74, 0.12);
    color: #16a34a;
  }
  /* "No" is the strongest claim in the table — give it assertive weight
     (dark slate), not the faintest mark. */
  .diff__mark.is-no {
    background: rgba(51, 65, 85, 0.14);
    color: #334155;
  }
  /* "Varies" is the softest state — a quiet amber pill of literal text, so
     nobody has to guess what a bare dash means. */
  .diff__pill.is-maybe {
    display: inline-block;
    padding: 0.28rem 0.7rem;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    background: rgba(180, 83, 9, 0.1);
    color: #b45309;
    white-space: nowrap;
  }
  .diff__table tbody tr:last-child th,
  .diff__table tbody tr:last-child td {
    border-bottom: none;
  }
</style>
