---
// "Areas We Serve" section (cpr-area): heading, nearby-city links, NAP, map.
// The nearby-city links are passed in as data (label + href derived from slug) —
// this is where the live site's Pineville→Charlotte bug is structurally avoided.
import SectionHeader from "@components/ui/SectionHeader.astro";
import Icon from "@components/ui/Icon.astro";
import { site } from "@data/site";
import { hasMapsKey } from "@data/maps";

interface CityLink {
  label: string;
  href: string;
}
interface Props {
  title?: string;
  sub?: string;
  infoHeading?: string;
  infoBlurb?: string;
  citiesLabel?: string;
  cities?: CityLink[];
  mapSrc?: string;
  mapTitle?: string;
  /** Plain Google Maps link — used for the "view larger map" affordance and as
   *  the fallback when no Maps Embed API key is configured. */
  mapLink?: string;
}
const {
  title = "We Respond Across the Charlotte Metro and Carolinas",
  sub = "Based in Fort Mill, SC, with crews across York County and the south Charlotte area. Pick your city below for local details.",
  infoHeading = "Fast Response Across the Region",
  infoBlurb = "Our trucks reach most of York County and south Charlotte in under an hour.",
  citiesLabel = "We Proudly Serve",
  cities = site.footerServiceAreas,
  mapSrc = site.mapEmbedSrc,
  mapTitle = `${site.name} service area map`,
  mapLink = site.mapLink,
} = Astro.props;
---

<section class="cpr-section area">
  <div class="cpr-section-inner">
    <SectionHeader title={title} sub={sub} />

    <div class="area__grid">
      <div class="area__info">
        {infoHeading && <h3 class="area__infohead">{infoHeading}</h3>}
        {infoBlurb && <p class="area__infoblurb">{infoBlurb}</p>}
        <p class="area__label">{citiesLabel}</p>
        <ul class="area__cities" role="list">
          {
            cities.map((c) => (
              <li>
                <a href={c.href}><span class="area__dot" aria-hidden="true" />{c.label}</a>
              </li>
            ))
          }
        </ul>

        <div class="area__nap">
          <p class="area__naptitle">{site.legalName}</p>
          <address class="area__address">
            <Icon name="pin" /> {site.address.street}, {site.address.city}, {site.address.state} {site.address.zip}
          </address>
          <a href={site.phoneHref} class="area__phone"><Icon name="phone" /> {site.phoneDisplay}</a>
        </div>
      </div>

      <div class="area__map">
        {
          hasMapsKey ? (
            <iframe
              src={mapSrc}
              title={mapTitle}
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              allowfullscreen
            />
          ) : (
            <a class="area__mapfallback" href={mapLink} rel="noopener" target="_blank">
              <Icon name="pin" />
              <span>View our {site.address.city} service area on Google Maps</span>
            </a>
          )
        }
      </div>
    </div>
  </div>
</section>

<style>
  .area__grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: var(--cpr-space-2xl);
    align-items: start;
  }
  .area__infohead {
    font-size: 1.35rem;
    margin-bottom: 0.4rem;
  }
  .area__infoblurb {
    color: var(--cpr-slate);
    margin-bottom: var(--cpr-space-lg);
  }
  .area__label {
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--cpr-red);
    margin-bottom: var(--cpr-space-md);
  }
  .area__cities {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.6rem;
    margin-bottom: var(--cpr-space-xl);
  }
  .area__cities a {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 0.5rem;
    font-weight: 600;
    color: var(--cpr-navy);
    border-radius: var(--cpr-radius-sm);
    transition: color 0.15s ease;
  }
  .area__cities a:hover {
    color: var(--cpr-red);
  }
  .area__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--cpr-red);
    flex: none;
  }
  .area__nap {
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    padding-top: var(--cpr-space-lg);
  }
  .area__naptitle {
    font-weight: 700;
    color: var(--cpr-navy);
    margin-bottom: 0.5rem;
  }
  .area__address {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    font-style: normal;
    color: var(--cpr-slate);
    margin-bottom: 0.5rem;
  }
  .area__address :global(svg) {
    color: var(--cpr-red);
    flex: none;
  }
  .area__phone {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-weight: 800;
    font-size: 1.2rem;
    color: var(--cpr-navy);
  }
  .area__phone :global(svg) {
    color: var(--cpr-red);
  }
  .area__map {
    border-radius: var(--cpr-radius-lg);
    overflow: hidden;
    box-shadow: var(--cpr-shadow-md);
    min-height: 380px;
    height: 100%;
  }
  .area__map iframe {
    width: 100%;
    height: 100%;
    min-height: 380px;
    border: 0;
    display: block;
  }
  .area__mapfallback {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    width: 100%;
    height: 100%;
    min-height: 380px;
    padding: var(--cpr-space-xl);
    text-align: center;
    background: var(--cpr-off-white, #f5f6f8);
    color: var(--cpr-navy);
    font-weight: 700;
  }
  .area__mapfallback :global(svg) {
    width: 2rem;
    height: 2rem;
    color: var(--cpr-red);
  }
  @media (max-width: 820px) {
    .area__grid {
      grid-template-columns: 1fr;
      gap: var(--cpr-space-xl);
    }
  }
  @media (max-width: 440px) {
    .area__cities {
      grid-template-columns: 1fr;
    }
  }
</style>
