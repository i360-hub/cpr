---
// Side-by-side before/after from a real job, each with a labeled badge.
import ResponsivePicture from "@components/ui/ResponsivePicture.astro";
import type { ImageMetadata } from "astro";
import SectionHeader from "@components/ui/SectionHeader.astro";

interface Props {
  before: ImageMetadata;
  after: ImageMetadata;
  beforeAlt: string;
  afterAlt: string;
  title?: string;
  sub?: string;
  caption?: string;
  light?: boolean;
  /** Shared frame ratio for BOTH photos, e.g. "3 / 4" (portrait) or "1 / 1".
      Pick to match the source photos — a landscape frame on portrait photos
      crops the subject out entirely. */
  ratio?: string;
  /** object-position per photo, e.g. "center 70%" to bias a crop toward the
      lower part of a portrait photo (where counters/floors are). */
  beforePos?: string;
  afterPos?: string;
}
const {
  before, after, beforeAlt, afterAlt,
  title = "Before & After",
  sub,
  caption,
  light = true,
  ratio = "4 / 3",
  beforePos = "center",
  afterPos = "center",
} = Astro.props;
---

<section class:list={["cpr-section", "beforeafter", { "cpr-section--light": light }]}>
  <div class="cpr-section-inner">
    <SectionHeader title={title} sub={sub} />
    <div class="ba__grid">
      <figure class="ba__item" style={`aspect-ratio:${ratio}`}>
        <span class="ba__badge ba__badge--before">Before</span>
        <ResponsivePicture src={before} alt={beforeAlt} widths={[420, 700, 960]} sizes="(max-width: 760px) 92vw, 480px" class="ba__img" objectPosition={beforePos} />
      </figure>
      <figure class="ba__item" style={`aspect-ratio:${ratio}`}>
        <span class="ba__badge ba__badge--after">After</span>
        <ResponsivePicture src={after} alt={afterAlt} widths={[420, 700, 960]} sizes="(max-width: 760px) 92vw, 480px" class="ba__img" objectPosition={afterPos} />
      </figure>
    </div>
    {caption && <p class="ba__caption">{caption}</p>}
  </div>
</section>

<style>
  .ba__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--cpr-space-lg);
  }
  .ba__item {
    position: relative;
    margin: 0;
    border-radius: var(--cpr-radius-lg);
    overflow: hidden;
    box-shadow: var(--cpr-shadow-md);
    /* The frame ratio lives on the container (set inline from the `ratio` prop)
       so both columns are identical; the <picture> and <img> fill it. */
  }
  .ba__item :global(picture) {
    display: block;
    width: 100%;
    height: 100%;
  }
  /* NOTE: must be a descendant :global(img) selector — a scoped `.ba__img` rule
     compiles to `.ba__img[data-astro-cid-…]`, and the img inside the
     ResponsivePicture child component never receives this component's scope
     attribute, so that rule silently never matches. (That was the original bug:
     the img rendered height:auto, top-aligned — a top slice of each photo.)
     object-position comes from the inline style ResponsivePicture sets. */
  .ba__item :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .ba__badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    z-index: 1;
    padding: 0.3rem 0.8rem;
    border-radius: var(--cpr-radius-pill, 999px);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--cpr-white);
  }
  .ba__badge--before {
    background: var(--cpr-slate, #64748b);
  }
  .ba__badge--after {
    background: var(--cpr-red);
  }
  .ba__caption {
    margin-top: var(--cpr-space-md);
    text-align: center;
    color: var(--cpr-slate-muted);
    font-size: 0.95rem;
  }
  @media (max-width: 620px) {
    .ba__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
