---
// Pricing-range table (wp-cost). Waterproofing page only.
import SectionHeader from "@components/ui/SectionHeader.astro";

interface Row {
  name: string;
  range: string;
}
interface Props {
  title: string;
  sub: string;
  note?: string;
  rows: Row[];
}
const { title, sub, note, rows } = Astro.props;
---

<section class="cpr-section cost">
  <div class="cpr-section-inner">
    <SectionHeader title={title} sub={sub} />

    <div class="cost__wrap">
      <table class="cost__table">
        <tbody>
          {
            rows.map((r) => (
              <tr>
                <th scope="row">{r.name}</th>
                <td>{r.range}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
      {note && <p class="cost__note">{note}</p>}
    </div>
  </div>
</section>

<style>
  .cost__wrap {
    max-width: 720px;
    margin-inline: auto;
  }
  .cost__table {
    width: 100%;
    border-collapse: collapse;
    background: var(--cpr-white);
    border-radius: var(--cpr-radius-lg);
    overflow: hidden;
    box-shadow: var(--cpr-shadow-md);
  }
  .cost__table th,
  .cost__table td {
    padding: 1.1rem 1.35rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.07);
    text-align: left;
  }
  .cost__table th {
    font-weight: 600;
    color: var(--cpr-navy);
  }
  .cost__table td {
    text-align: right;
    font-weight: 800;
    color: var(--cpr-red);
    white-space: nowrap;
  }
  .cost__table tr:last-child th,
  .cost__table tr:last-child td {
    border-bottom: none;
  }
  .cost__note {
    margin-top: var(--cpr-space-md);
    text-align: center;
    font-size: 0.9rem;
    color: var(--cpr-slate-muted);
    font-style: italic;
  }
</style>
