---
// Thin wrapper over astro:assets <Picture>: avif + webp output, responsive
// widths, with a `priority` mode for the LCP hero (eager + fetchpriority=high,
// never lazy). Everything else defaults to lazy.
//
// fallbackFormat="jpg" — the <img> fallback is a JPEG, not a PNG. Our sources
// are photos; a PNG fallback ballooned to ~2.9MB at 1920w (17MB of PNGs
// build-wide). JPEG keeps the fallback ~150KB for the rare client that can't
// take avif/webp, with no visible quality change.
//
// `priority` does NOT emit the <link rel=preload> — a preload is only worth
// anything ahead of the parser, and a component renders where it sits (this one
// landed ~300 bytes before its own <picture>, buying ~70ms of a claimed 650ms).
// The preload lives in BaseLayout's <head>: pass `preloadImage` there with the
// same src/widths/sizes used here so the hashed AVIF URLs match and the browser
// reuses the preloaded response instead of downloading twice.
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";
import { RESPONSIVE_WIDTHS, widthsFor } from "@lib/images";

interface Props {
  src: ImageMetadata;
  alt: string;
  widths?: number[];
  sizes?: string;
  priority?: boolean;
  class?: string;
  pictureClass?: string;
  objectPosition?: string;
}

const {
  src,
  alt,
  widths = RESPONSIVE_WIDTHS,
  sizes = "100vw",
  priority = false,
  class: className,
  pictureClass,
  objectPosition,
} = Astro.props;

const finalWidths = widthsFor(src, widths);
---

<Picture
  src={src}
  alt={alt}
  formats={["avif", "webp"]}
  fallbackFormat="jpg"
  widths={finalWidths}
  sizes={sizes}
  loading={priority ? "eager" : "lazy"}
  decoding={priority ? "sync" : "async"}
  fetchpriority={priority ? "high" : "auto"}
  class={className}
  pictureAttributes={pictureClass ? { class: pictureClass } : undefined}
  style={objectPosition ? `object-position:${objectPosition}` : undefined}
/>
